# Fitur AI (Foto & Asisten) — provider TokenRouter (OpenAI-compatible), opsional.
# Isi TOKENROUTER_API_KEY agar Foto & Asisten aktif. Kosong -> aplikasi tetap
# jalan penuh tanpa AI (Telusur, Tabel Gejala), fitur AI degrade mulus.
TOKENROUTER_API_KEY=
TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1

# Model per fitur (opsional, boleh ditimpa tanpa ubah kode):
TOKENROUTER_FOTO_MODEL=openai/gpt-4o-mini
TOKENROUTER_ASISTEN_MODEL=deepseek/deepseek-v4-flash
